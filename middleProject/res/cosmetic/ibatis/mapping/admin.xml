	  set mem_blacklist='BLACK'
	where mem_id=#mem_id#
</update> -->

<update id="updateBlackList" parameterClass="String">
	update member
	  set mem_blacklist='BLACK'
	where mem_id=#mem_id#
</update> 

<update id="deleteBlackList" parameterClass="String">
	update member
	   set mem_blacklist='(null)'
	  where mem_id=#mem_id#
</update>


