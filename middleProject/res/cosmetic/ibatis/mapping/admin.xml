<sqlMap namespace="admin">

<!-- 회원 관리 -->
<select id="selectMember" parameterClass="String" resultClass="memberVO">
	select * from mem_detail where mem_id=#mem_id#
</select>

<select id="getAllMember" resultClass="memberVO">
	select a.mem_id, b.mem_name, a.mem_email, a.mem_tel from mem_detail a, member b
    where a.mem_id=b.mem_id and b.mem_type='MT02'
</select>

<delete id="deleteMember" parameterClass="String">
	delete
	from member
	where mem_id=#mem_id#
</delete>

<!-- 블랙리스트 -->
<select id="getAllBlackList" parameterClass="String" resultClass="adminVO">
	select * from member where mem_blacklist='BLACK'
</select>

<!-- <update id="updateBlackList" parameterClass="String">
